    "faq": {
      "title": "Frequently Asked Questions",
      "subtitle": "Everything you need to know about our services.",
      "q1": "How often do ocean and air shipments depart?",
      "a1": "We have weekly departures to ensure your purchases arrive on time.",
      "q2": "How long does it take for my package to arrive from Miami?",
