    "howItWorks": {
      "title": "How does Narbox work?",
      "subtitle": "Shop at your favorite US stores, send to our Miami P.O. box, and receive in Panama via ocean or air freight.",
      "step1Title": "Shop Online",
      "step1Text": "Make your online purchases at US stores (Amazon, Shein, Walmart, etc.) and use our Miami locker address.",
      "step2Title": "We Ship to Panama",
      "step2Text": "We receive your packages in Miami, consolidate if necessary, and ship them via ocean or air freight to Panama.",
      "step3Title": "Receive your Order",
      "step3Text": "Pick up at our offices or get home delivery in Panama City."
    },
    "services": {
      "title": "Our Services",
      "subtitle": "Tailored solutions for every type of cargo or purchase.",
      "card1Title": "Online Shopping & P.O. Box",
      "card1Text": "We provide a Miami address for your US purchases and handle the rest.",
      "card2Title": "Ocean and Air Freight",
      "card2Text": "We choose the best option tailored to the load type, volume, and urgency.",
      "card3Title": "Vehicle & Heavy Cargo Import",
      "card3Text": "We assist with logistics and customs to bring in vehicles and oversized merchandise.",
