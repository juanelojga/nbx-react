# Development image — source code is NOT copied here.
# The project root is mounted as a volume at runtime (see docker-compose.yml),
# so changes on the host are immediately reflected inside the container.
FROM node:22-alpine

# Install libc compatibility for certain native modules on Alpine
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy only the dependency manifests first so Docker can cache this layer.
# The actual source is provided via the volume mount at runtime.
COPY package.json package-lock.json* ./

# Install all dependencies (including devDependencies needed for next dev)
# Use npm install instead of npm ci to tolerate lock file version differences
# between the host npm and the container npm.
RUN npm install

# Next.js dev server listens on port 3000 inside the container.
# The HOST_PORT → 3000 mapping is handled in docker-compose.yml.
EXPOSE 3000

# HOSTNAME=0.0.0.0 ensures Next.js binds to all interfaces, not just loopback,
# which is required for Docker port-forwarding to work.
ENV HOSTNAME=0.0.0.0

CMD ["npm", "run", "dev"]
