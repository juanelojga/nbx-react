# .env.docker.example — Template for .env.docker
#
# Copy this file to .env.docker and fill in the values:
#   cp .env.docker.example .env.docker
#
# .env.docker is gitignored. This example file IS committed so all
# contributors know which variables are required for Docker.

# ----------------------------------------------------------------------------
# HOST PORT
# Port exposed on your machine. Change this per project to avoid collisions
# when running multiple Dockerized apps in parallel.
# Example: 3001 for this project, 3002 for another.
# ----------------------------------------------------------------------------
HOST_PORT=3001

# ----------------------------------------------------------------------------
# GRAPHQL ENDPOINT (Docker override)
# When running inside Docker, "localhost" refers to the container itself,
# not your machine. Use "host.docker.internal" to reach the Django backend
# running on your host. This overrides the value in .env.local.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://host.docker.internal:8000/graphql
